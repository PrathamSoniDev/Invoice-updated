# InvoiceGen — frontend (Vite) environment variables
# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public API key 
VITE_SUPABASE_ANON_KEY=

# Razorpay PUBLIC key id 
VITE_RAZORPAY_KEY=

# Base URL of the Express server in server/ (email sending, payment order creation, etc.), e.g. http://localhost:4000 
VITE_API_URL=
