# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here

# Verified sending domain on Resend
RESEND_DOMAIN=selltechindproductions.in

# Port the Express server listens on
PORT=4000


PAYTM_ENVIRONMENT=STAGE
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB

FRONTEND_URL=http://localhost:5173

# Supabase service-role client — used ONLY by the payment webhook /
# reconciliation flow (server/services/supabaseAdmin.js) to write to the
# database with no logged-in user session. Get these from Supabase Project
# Settings → API. NEVER the anon key here, and never expose this key to the
# frontend/browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay Dashboard → Settings → Webhooks → set this to whatever secret you
# configure there (must match exactly). Required for POST /api/webhooks/razorpay
# signature verification.
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Razorpay OAuth (Technology Partner) ------------------------------------
# Lets companies connect Razorpay via "Connect with Razorpay" instead of
# manually entering a Key ID/Key Secret (server/routes/razorpayOauthRoutes.js).
# Requires this project to be an approved Razorpay Technology Partner —
# https://razorpay.com/docs/partners/technology-partners/ — and an
# application created on the Partner Dashboard. Until CLIENT_ID/CLIENT_SECRET
# are set, GET /api/gateways/razorpay/oauth/authorize returns 503 and the
# Settings page falls back to manual entry; nothing else in the app is
# affected.
RAZORPAY_OAUTH_CLIENT_ID=
RAZORPAY_OAUTH_CLIENT_SECRET=
# Must exactly match a redirect URI whitelisted on the Partner Dashboard
# application, e.g. https://yourapp.com/api/gateways/razorpay/oauth/callback
RAZORPAY_OAUTH_REDIRECT_URI=
# Any long random string — used to HMAC-sign the CSRF `state` value for the
# OAuth round trip (server/services/oauthState.js). Generate with e.g.
# `openssl rand -hex 32`.
RAZORPAY_OAUTH_STATE_SECRET=
# Optional. 'test' to force the development client during integration
# testing; omit (defaults to live) once using the production client.
RAZORPAY_OAUTH_MODE=

# Same passphrase configured as GATEWAY_CREDENTIALS_ENCRYPTION_KEY on the
# save-gateway-credentials/get-gateway-status Supabase Edge Functions — the
# OAuth callback/revoke routes above call the same set_razorpay_oauth_tokens/
# get_razorpay_oauth_token/clear_razorpay_oauth_tokens SQL functions those
# Edge Functions use for the manual-credentials path, so the key must match.
GATEWAY_CREDENTIALS_ENCRYPTION_KEY=

# Supabase anon (public) key — used ONLY to verify the caller's JWT and look
# up their role/companyId before issuing an OAuth `state` (server/services/
# callerAuth.js). This is the same anon key already used by the frontend
# (VITE_SUPABASE_ANON_KEY); it is safe to duplicate here since it's public.
SUPABASE_ANON_KEY=
