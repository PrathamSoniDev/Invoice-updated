# InvoiceGen Backend Environment Configuration
# Copy this file to .env and fill in the values

# =====================
# APPLICATION
# =====================
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=InvoiceGen
APP_URL=http://localhost:5173

# =====================
# DATABASE (Supabase PostgreSQL)
# =====================
DATABASE_URL="mysql://root:@localhost:3306/invoicegen"

# =====================
# REDIS
# =====================
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=invoicegen:

# =====================
# JWT AUTHENTICATION
# =====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_REMEMBER_ME_EXPIRES_IN=30d

# =====================
# CORS
# =====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================
# EMAIL (Resend)
# =====================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@invoicegen.com
EMAIL_FROM_NAME=InvoiceGen

# =====================
# EMAIL (SMTP Alternative)
# =====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# =====================
# STORAGE (Cloudinary)
# =====================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=invoicegen

# =====================
# PAYMENT GATEWAY - RAZORPAY
# =====================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# =====================
# PAYMENT GATEWAY - PAYTM
# =====================
PAYTM_MERCHANT_ID=your-merchant-id
PAYTM_MERCHANT_KEY=your-merchant-key
PAYTM_ENVIRONMENT=TEST

# =====================
# WHATSAPP (Future)
# =====================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# =====================
# EXTERNAL INTEGRATIONS
# =====================
TALLY_API_URL=http://localhost:9000

# =====================
# LOGGING
# =====================
LOG_LEVEL=debug
LOG_FORMAT=dev

# =====================
# RATE LIMITING
# =====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# =====================
# SECURITY
# =====================
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_SESSIONS=5

# =====================
# BULLMQ QUEUES
# =====================
QUEUE_EMAIL=email:queue
QUEUE_WHATSAPP=whatsapp:queue
QUEUE_EXPORT=export:queue
QUEUE_NOTIFICATION=notification:queue
QUEUE_AUDIT=audit:queue
QUEUE_SYNC=sync:queue
QUEUE_INVOICE=invoice:queue
QUEUE_REPORT=report:queue
QUEUE_CLEANUP=cleanup:queue
